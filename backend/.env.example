# Server
PORT=5000

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Authentication
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=G-Rank <noreply@grank.vega8991.com>

# Frontend URL (for redirects and CORS)
FRONTEND_URL=https://grank.vega8991.com

# Riot Games API
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Riot OAuth (RSO) — optional, only needed for OAuth flow
RIOT_CLIENT_ID=your-rso-client-id
RIOT_CLIENT_SECRET=your-rso-client-secret
RIOT_REDIRECT_URI=https://grank-backend.onrender.com/api/riot/oauth/callback
